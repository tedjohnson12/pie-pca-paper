@article{way2025,
  title = {{{TRAPPIST-1}} d: {{Exo-Venus}}, {{Exo-Earth}}, or {{Exo-Dead}}?},
  shorttitle = {{{TRAPPIST-1}} d},
  author = {Way, M. J.},
  year = 2025,
